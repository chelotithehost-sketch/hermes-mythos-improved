# Hermes-Mythos Environment Configuration
# Copy this file to .env and fill in your values

# LLM Provider API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Server
HOST=0.0.0.0
PORT=8000
DATA_DIR=data
DB_PATH=data/hermes.db

# Pipeline settings
MAX_REVISIONS=3
CHAPTER_COUNT=12
WORDS_PER_CHAPTER=3000

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# WhatsApp via Twilio (optional)
WHATSAPP_ACCOUNT_SID=
WHATSAPP_AUTH_TOKEN=
WHATSAPP_FROM=
WHATSAPP_TO=
